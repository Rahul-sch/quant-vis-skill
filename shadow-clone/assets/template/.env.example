# Shadow Clone Configuration
# Copy to .env and fill in values

# Execution mode: paper | alpaca
EXECUTION_MODE=paper

# Alpaca (only needed if EXECUTION_MODE=alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Risk controls
MAX_POSITION_SIZE=1000
DAILY_LOSS_LIMIT=500
COOLDOWN_SECONDS=30
DUPLICATE_WINDOW_SECONDS=60

# Webhook security (optional shared secret)
WEBHOOK_SECRET=

# Allowed tickers (comma-separated, empty = allow all)
ALLOWED_TICKERS=
